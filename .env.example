TINY_CLAW_PROVIDER=openai-compatible
TINY_CLAW_API_KEY=replace-with-your-api-key
TINY_CLAW_BASE_URL=https://api.deepseek.com
TINY_CLAW_MODEL=deepseek-v4-flash
TINY_CLAW_TIMEOUT_SECONDS=60
TINY_CLAW_MAX_TOKENS=4096
TINY_CLAW_STREAM=true

# Optional comma-separated Codex-style skills loaded from
# .tiny-claw/skills/<skill-id>/SKILL.md. Enabled skills are advertised as compact
# metadata first; the model can call load_skill to read a model-invokable skill.
# TINY_CLAW_SKILLS=rust,git

# To try an Anthropic/Claude-compatible endpoint, change the provider and
# set the base URL/model expected by that endpoint.
# TINY_CLAW_PROVIDER=claude-compatible
# TINY_CLAW_BASE_URL=https://api.deepseek.com/anthropic
# TINY_CLAW_MODEL=deepseek-v4-flash
# TINY_CLAW_ANTHROPIC_VERSION=2023-06-01
