# Copy this file to .env.feishu and fill in values from your Feishu app.
#
# Required. Feishu developer console -> app credentials.
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required if you configure a Verification Token in Feishu event subscription.
# The callback rejects events whose token does not match this value.
FEISHU_VERIFY_TOKEN=xxxxxxxxxxxxxxxx

# Leave empty for now. Encrypted callbacks are intentionally not implemented yet.
FEISHU_ENCRYPT_KEY=

# Optional. Agent workspace for Feishu-triggered runs. If omitted, the gateway
# creates and uses .feishu-workspace under the process launch directory.
# Set this when the bot should operate on a real project directory.
# TINY_CLAW_WORKSPACE=/srv/tiny-claw/workspace

# Local server bind address. Use a public HTTPS tunnel or reverse proxy to
# forward https://your-public-host/feishu/events to this host and port.
FEISHU_CALLBACK_HOST=0.0.0.0
FEISHU_CALLBACK_PORT=48080

# Optional nginx rendering values for scripts/render-feishu-nginx.sh.
# Feishu event subscription URL will be:
# https://FEISHU_PUBLIC_HOST/feishu/events
FEISHU_PUBLIC_HOST=a.com

# nginx should normally proxy to loopback even when the Rust server binds
# FEISHU_CALLBACK_HOST=0.0.0.0.
FEISHU_UPSTREAM_HOST=127.0.0.1

# Defaults match Let's Encrypt certbot paths for FEISHU_PUBLIC_HOST if omitted.
# FEISHU_TLS_CERT=/etc/letsencrypt/live/a.com/fullchain.pem
# FEISHU_TLS_KEY=/etc/letsencrypt/live/a.com/privkey.pem
